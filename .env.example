# Supabase / Postgres
# Required: database used for transactions, journal lines, and receipt batch tracking
DATABASE_URL=
# Required: auth/session handling for the webapp
NEXT_PUBLIC_SUPABASE_URL=
# Required: auth/session handling for the webapp
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: public app URL used for callbacks and links
NEXT_PUBLIC_APP_URL=https://accounting.daditrading.com
# Optional: restrict app access to one email domain
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=daditrading.com

# Cloudflare R2
# Required for receipt upload/view flows and for final batch submission
R2_ACCOUNT_ID=
# Required for receipt upload/view flows and for final batch submission
R2_ACCESS_KEY_ID=
# Required for receipt upload/view flows and for final batch submission
R2_SECRET_ACCESS_KEY=
# Required for receipt upload/view flows and for final batch submission
R2_BUCKET=
# Optional: public base URL if you want a direct public object URL in results/debugging
R2_PUBLIC_BASE_URL=

# Batch receipt OCR
# Required for the batch import feature. Use "openai" or "gemini".
RECEIPT_OCR_PROVIDER=openai
# Optional: number of receipts processed concurrently
RECEIPT_BATCH_CONCURRENCY=5

# Gemini OCR path
# Required only if RECEIPT_OCR_PROVIDER=gemini, or if you want Gemini available as a fallback
GEMINI_API_KEY=
# Optional: Gemini model override
RECEIPT_OCR_GEMINI_MODEL=gemini-2.5-pro

# OpenAI OCR path
# Required only if RECEIPT_OCR_PROVIDER=openai, or if you want OpenAI available as a fallback
OPENAI_API_KEY=
# Optional: default low-cost OCR model for first pass
RECEIPT_OCR_OPENAI_MODEL=gpt-5.4-mini
# Optional: higher-quality retry model used once for low-confidence results
RECEIPT_OCR_OPENAI_LOW_CONFIDENCE_MODEL=gpt-5.5
# Optional: cap on response output tokens per OCR request
RECEIPT_OCR_OPENAI_MAX_OUTPUT_TOKENS=1200
